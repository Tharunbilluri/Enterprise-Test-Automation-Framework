# =============================================================================
# Enterprise Test Automation Framework — Environment Variables
# Copy this file to `.env` and adjust values for your local/CI environment.
# Never commit secrets. Sauce Demo credentials below are publicly documented.
# =============================================================================

# Target application
BASE_URL=https://www.saucedemo.com/
BASE_TITLE=Swag Labs

# Browser: chrome | edge | firefox
BROWSER=chrome
HEADLESS=false
IMPLICIT_WAIT=0
EXPLICIT_WAIT=15
PAGE_LOAD_TIMEOUT=30
WINDOW_WIDTH=1920
WINDOW_HEIGHT=1080

# Automation engine: selenium | playwright
AUTOMATION_ENGINE=selenium

# Standard Sauce Demo users (public demo site)
VALID_USERNAME=standard_user
VALID_PASSWORD=secret_sauce
INVALID_USERNAME=invalid_user
INVALID_PASSWORD=wrong_password
LOCKED_USERNAME=locked_out_user

# Reporting & artifacts
LOG_LEVEL=INFO
SCREENSHOT_ON_FAILURE=true
REPORTS_DIR=reports
SCREENSHOTS_DIR=screenshots
LOGS_DIR=logs

# Parallel / retry defaults (can still be overridden via CLI)
PYTEST_WORKERS=auto
RERUNS=1
RERUNS_DELAY=1
